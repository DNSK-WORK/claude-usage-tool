# Anthropic Admin API Key
# Get this from: https://console.anthropic.com/settings/admin-keys
# Must start with sk-ant-admin-
ANTHROPIC_ADMIN_KEY=sk-ant-admin-your-key-here

# Telegram Bot Notifications (optional)
# 1. Create a bot via @BotFather on Telegram and get the token
# 2. Send a message to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
